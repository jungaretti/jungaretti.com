{
  "name": "jungaretti.com",
  "version": "1.0.0",
  "main": "index.js",
  "license": "GPL",
  "private": true,
  "scripts": {
    "format": "prettier --write src README.md",
    "clean": "rimraf build",
    "build:tailwind": "tailwindcss -i src/css/styles.css -o build/css/styles.css -m",
    "build:eleventy": "eleventy",
    "build": "NODE_ENV=production npm-run-all clean build:*",
    "dev:eleventy": "eleventy --serve",
    "dev:tailwind": "tailwindcss -i src/css/styles.css -o build/css/styles.css -w",
    "dev": "npm-run-all clean --parallel dev:*"
  },
  "devDependencies": {
    "@11ty/eleventy": "^0.12.1",
    "autoprefixer": "^10.2.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.3.5",
    "prettier": "2.3.1",
    "rimraf": "^3.0.2",
    "tailwindcss": "^2.2.4"
  }
}
